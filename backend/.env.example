DEBUG=True
SECRET_KEY=django-insecure-placeholder-for-local-dev-must-be-long-enough
ALLOWED_HOSTS=localhost,127.0.0.1

# DATABASE_URL=postgres://user:pass@localhost:5432/dbname

# Authentication feature flags
AUTH_REQUIRE_EMAIL_VERIFICATION=True
AUTH_REQUIRE_DEVICE_VERIFICATION=True
AUTH_OTP_LENGTH=6
AUTH_OTP_EXPIRY_MINUTES=10
AUTH_MAX_OTP_ATTEMPTS=3
AUTH_MAX_OTP_RESENDS=3
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_ACCOUNT_LOCK_MINUTES=15

# JWT lifetimes
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# Infrastructure providers
EMAIL_PROVIDER=console

# # ---------------------------------------------------
# # EMAIL CORE
# # ---------------------------------------------------
# EMAIL_PROVIDER=console
# DEFAULT_FROM_EMAIL=noreply@recon.local

# # ---------------------------------------------------
# # SMTP (if used)
# # ---------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false

# # ---------------------------------------------------
# # ANYMAIL PROVIDERS (API BASED)
# # ---------------------------------------------------

# # SendGrid
# SENDGRID_API_KEY=

# # Brevo
# BREVO_API_KEY=

# # Mailgun
# MAILGUN_API_KEY=

# # MailerSend
# MAILERSEND_API_TOKEN=

# # Postmark
# POSTMARK_SERVER_TOKEN=

# # AWS SES (IAM-based usually)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# # ---------------------------------------------------
# # EMAIL SETTINGS
# # ---------------------------------------------------
# EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=30
# LOGIN_OTP_TTL_MINUTES=10
# FRONTEND_VERIFY_EMAIL_URL=https://recon.app/verify-email